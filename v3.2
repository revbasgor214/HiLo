<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Hi-Lo Challenge</title>
    <style>
        :root { --accent: #ff00ff; --bg: #0a0a12; --gold: #ffd700; --red: #ff4757; --green: #2ed573; }
        body { 
            background: var(--bg); color: #fff; font-family: 'Avenir Next', sans-serif; 
            text-align: center; margin: 0; padding: 10px; 
            padding-bottom: 120px; 
            overflow: hidden; touch-action: manipulation; 
        }
        
        .header { display: flex; justify-content: space-between; align-items: center; padding: 5px 10px; margin-bottom: 2px; }
        .logo { font-size: 1.1rem; font-weight: 900; color: var(--gold); font-style: italic; }
        #game-counter { background: var(--accent); color: #fff; padding: 4px 12px; border-radius: 20px; font-size: 0.7rem; font-weight: 900; }

        .hud { background: rgba(255,255,255,0.05); border: 2px solid var(--accent); padding: 10px; border-radius: 15px; display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin: 0 5px 5px 5px; }
        .hud-val { font-size: 1.2rem; font-weight: 900; }
        .hud-label { font-size: 0.5rem; color: var(--accent); text-transform: uppercase; letter-spacing: 1px; }

        #round-title { font-size: 1.4rem; font-weight: 900; color: var(--gold); margin-top: 5px; }
        #round-sub { font-size: 0.65rem; color: #aaa; margin-bottom: 15px; text-transform: uppercase; font-weight: 800; }

        .card-area { display: flex; justify-content: center; gap: 6px; margin: 5px 0; min-height: 220px; }
        .card-slot { width: 31%; }
        .card { width: 100%; aspect-ratio: 2/3; background: #fff; color: #000; border-radius: 10px; display: flex; flex-direction: column; align-items: center; justify-content: center; font-size: 1.6rem; font-weight: 900; position: relative; border: 3px solid #333; box-shadow: 3px 3px 0px rgba(0,0,0,0.5); }
        .card.dealer { border-color: var(--accent); animation: bounceIn 0.3s; }
        .red-suit { color: var(--red) !important; }

        .btn-group { display: flex; flex-direction: column; gap: 4px; margin-top: 5px; }
        .choice-btn { background: #1a1a2e; border: 1px solid #444; color: #fff; padding: 10px 0; border-radius: 8px; font-size: 0.75rem; font-weight: 900; -webkit-tap-highlight-color: transparent; }
        .choice-btn.active { background: var(--accent); border-color: #fff; transform: translateY(-2px); }
        
        .bottom-ui { position: fixed; bottom: 50px; left: 0; width: 100%; display: flex; align-items: flex-end; justify-content: space-between; padding: 0 15px; box-sizing: border-box; pointer-events: none; }
        .main-btn-wrapper { width: 72%; pointer-events: auto; }
        .main-btn { background: var(--gold); color: #000; border: none; width: 100%; padding: 18px; border-radius: 15px; font-weight: 900; text-transform: uppercase; font-size: 1rem; box-shadow: 0 4px 0px #b88e00; }
        .main-btn:active { transform: translateY(2px); box-shadow: 0 1px 0px #b88e00; }

        .mascot-wrapper { width: 25%; display: flex; flex-direction: column; align-items: center; pointer-events: auto; }
        #mascot { font-size: 3rem; filter: drop-shadow(0 0 10px var(--accent)); line-height: 1; }
        #bubble { background: #fff; color: #000; padding: 3px 8px; border-radius: 10px; font-size: 0.6rem; font-weight: 900; margin-bottom: 4px; border: 2px solid var(--accent); display: none; white-space: nowrap; }

        @keyframes bounceIn { from { transform: scale(0.5); opacity: 0; } to { transform: scale(1); opacity: 1; } }
        .tag { font-size: 0.5rem; font-weight: 900; padding: 2px 5px; border-radius: 4px; margin-top: 3px; display: inline-block; }
        .win-tag { background: var(--green); color: #000; }
        .loss-tag { background: var(--red); color: #fff; }
    </style>
</head>
<body>

    <div class="header">
        <div class="logo">HI-LO CHALLENGE</div>
        <div id="game-counter">GAME 1/10</div>
    </div>
    
    <div class="hud">
        <div><span class="hud-label">Match Total</span><span class="hud-val" id="banked">0</span></div>
        <div><span class="hud-label">Current Total</span><span class="hud-val" id="pot" style="color:var(--gold)">0</span></div>
    </div>

    <div id="round-title">READY?</div>
    <div id="round-sub">10 Games for the Grand Prize</div>

    <div class="card-area" id="game-board"></div>
    
    <div class="bottom-ui">
        <div class="main-btn-wrapper" id="controls">
            <button class="main-btn" onclick="initAudio(); startGame()">DEAL</button>
        </div>
        <div class="mascot-wrapper">
            <div id="bubble">WIN!</div>
            <div id="mascot">🐵</div>
        </div>
    </div>

    <script>
        let deck = [], turnPot = 0, bankedTotal = 0, round = 1, currentGame = 1, flips = [], picks = [null, null, null];
        let audioCtx = null;

        function initAudio() { if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)(); }

        function playSound(type) {
            if (!audioCtx) return; const now = audioCtx.currentTime;
            if (type === 'click') {
                const o = audioCtx.createOscillator(); const g = audioCtx.createGain();
                o.type = 'triangle'; o.frequency.setValueAtTime(140, now); 
                o.frequency.exponentialRampToValueAtTime(40, now + 0.12);
                g.gain.setValueAtTime(0.5, now);
                g.gain.linearRampToValueAtTime(0, now + 0.12);
                o.connect(g); g.connect(audioCtx.destination); o.start(); o.stop(now + 0.12);
            } else if (type === 'win') {
                const o = audioCtx.createOscillator(); const g = audioCtx.createGain();
                o.type = 'triangle'; o.frequency.setValueAtTime(600, now); o.frequency.exponentialRampToValueAtTime(1200, now + 0.2);
                g.gain.setValueAtTime(0.1, now); g.gain.linearRampToValueAtTime(0, now + 0.2);
                o.connect(g); g.connect(audioCtx.destination); o.start(); o.stop(now + 0.2);
            } else if (type === 'fail') {
                const o = audioCtx.createOscillator(); const g = audioCtx.createGain();
                o.type = 'sawtooth'; o.frequency.setValueAtTime(100, now); o.frequency.linearRampToValueAtTime(30, now + 0.4);
                g.gain.setValueAtTime(0.15, now); g.gain.linearRampToValueAtTime(0, now + 0.4);
                o.connect(g); g.connect(audioCtx.destination); o.start(); o.stop(now + 0.4);
            }
        }

        function setMascot(state) {
            const m = document.getElementById('mascot');
            const b = document.getElementById('bubble');
            if (state === 'win') { m.innerText = '🤩'; b.innerText = "WIN!"; b.style.display = 'block'; }
            else if (state === 'lose') { m.innerText = '🙈'; b.innerText = "BUST!"; b.style.display = 'block'; }
            else if (state === 'horns') { m.innerText = '🤘'; b.innerText = "RISK!"; b.style.display = 'block'; }
            else { m.innerText = '🐵'; b.style.display = 'none'; }
            setTimeout(() => b.style.display = 'none', 1800);
        }

        function createCardHTML(c, isDealer = false) {
            let v = c.v === 1 ? 'A' : c.v === 11 ? 'J' : c.v === 12 ? 'Q' : c.v === 13 ? 'K' : c.v;
            let color = (c.s === '♥' || c.s === '♦') ? 'red-suit' : '';
            return `<div class="card ${isDealer?'dealer':''} ${color}"><div style="font-size:2rem;">${c.s}</div><div style="position:absolute;top:3px;left:5px;font-size:0.7rem;">${v}</div></div>`;
        }

        function startGame() {
            if (currentGame > 10) { location.reload(); return; }
            deck = []; for(let s of ['♠','♣','♥','♦']) for(let v=1; v<=13; v++) deck.push({v, s});
            deck.sort(() => Math.random() - 0.5); turnPot = 0; round = 1; dealRound();
        }

        function dealRound() {
            flips = [deck.pop(), deck.pop(), deck.pop()]; picks = [null, null, null]; render();
            const titles = ["ROUND 1: THE FLIP", "ROUND 2: THE GRAVY", "ROUND 3: THE HORNS"];
            const subs = ["Win 2 to Advance", "Win 2 (Ties Free)", "3 in a Row = BUST"];
            document.getElementById('round-title').innerText = titles[round-1];
            document.getElementById('round-sub').innerText = subs[round-1];
            document.getElementById('pot').innerText = turnPot;
            document.getElementById('game-counter').innerText = `GAME ${currentGame}/10`;
            if (round === 3) setMascot('horns');
        }

        function setPick(i, p) { playSound('click'); picks[i] = p; render(); }

        function render(res = null, tags = []) {
            const board = document.getElementById('game-board'); board.innerHTML = '';
            flips.forEach((c, i) => {
                let html = `<div class="card-slot">${createCardHTML(c)}`;
                if (!res) {
                    html += `<div class="btn-group"><button class="choice-btn ${picks[i]==='H'?'active':''}" onclick="setPick(${i},'H')">HI</button><button class="choice-btn ${picks[i]==='L'?'active':''}" onclick="setPick(${i},'L')">LO</button>${round<3?`<button class="choice-btn ${picks[i]==='T'?'active':''}" onclick="setPick(${i},'T')">TIE</button>`:''}</div>`;
                } else {
                    html += `<div style="font-size:0.5rem;margin:3px 0;font-weight:900;color:#aaa;">${picks[i]}</div>${createCardHTML(res[i],true)}<div class="tag ${tags[i].class}">${tags[i].text}</div>`;
                }
                board.innerHTML += html + `</div>`;
            });
            if (!res && picks.every(p => p !== null)) document.getElementById('controls').innerHTML = `<button class="main-btn" onclick="reveal()">REVEAL</button>`;
        }

        function reveal() {
            let wins = 0, pts = 0, resCards = [], tags = [];
            flips.forEach((f, i) => {
                let c = deck.pop(); resCards.push(c);
                let isW = (picks[i]==='H' && c.v > f.v) || (picks[i]==='L' && c.v < f.v);
                let isT = (c.v === f.v);
                if (picks[i] === 'T' && isT) { wins++; pts += 6; tags.push({text: "TIE +6", class: "win-tag"}); }
                else if (isW) { wins++; pts += 2; tags.push({text: "WIN +2", class: "win-tag"}); }
                else if (isT && round === 2) { wins++; tags.push({text: "PUSH", class: "win-tag"}); }
                else tags.push({text: "MISS", class: "loss-tag"});
            });
            render(resCards, tags);
            setTimeout(() => {
                const ctrl = document.getElementById('controls');
                if (round === 1) {
                    if (wins >= 2) { turnPot += pts; round = 2; playSound('win'); ctrl.innerHTML = `<button class="main-btn" onclick="dealRound()">CONTINUE</button>`; }
                    else finishTurn("GAME FAILED", 0);
                } else if (round === 2) {
                    if (wins >= 2) { turnPot += pts; round = 3; playSound('win'); ctrl.innerHTML = `<button class="main-btn" onclick="dealRound()">CONTINUE</button>`; }
                    else { bankedTotal += turnPot; finishTurn("SAVED AT GRAVY", turnPot); }
                } else {
                    if (wins === 3) finishTurn("TRIPLE BUST!", 0);
                    else { bankedTotal += (turnPot + pts); playSound('win'); finishTurn("BANKED!", turnPot + pts); }
                }
                document.getElementById('banked').innerText = bankedTotal;
            }, 700);
        }

        function finishTurn(msg, amt) {
            currentGame++;
            if (currentGame > 10) {
                let rank = bankedTotal > 50 ? "LEGEND" : bankedTotal > 20 ? "PRO" : "ROOKIE";
                document.getElementById('round-title').innerText = "MATCH OVER";
                document.getElementById('round-sub').innerText = `RANK: ${rank} | FINAL: ${bankedTotal}`;
                document.getElementById('controls').innerHTML = `<button class="main-btn" onclick="location.reload()">NEW MATCH</button>`;
                setMascot(bankedTotal > 20 ? 'win' : 'lose');
            } else {
                document.getElementById('round-title').innerText = amt > 0 ? "WINNER!" : "GAME OVER";
                document.getElementById('round-sub').innerText = msg;
                document.getElementById('controls').innerHTML = `<button class="main-btn" onclick="startGame()">CONTINUE</button>`;
                if (amt === 0) { playSound('fail'); setMascot('lose'); } else { setMascot('win'); }
            }
            document.getElementById('pot').innerText = 0;
        }
    </script>
</body>
</html>
